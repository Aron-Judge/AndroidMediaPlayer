<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Core app theme; Compose provides the colors, this keeps system bars dark -->
    <style name="Theme.MediaPlayer" parent="Theme.AppCompat.DayNight.NoActionBar">
        <!-- Fallback accent (for any View-based UI you might still use) -->
        <item name="colorPrimary">#00EEFF</item>

        <!-- System bars -->
        <item name="android:statusBarColor">#FF000000</item>
        <item name="android:navigationBarColor">#FF000000</item>

        <!-- Launch screen / background -->
        <item name="android:windowBackground">@android:color/black</item>
    </style>
</resources>